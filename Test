-- ==============================================
-- 🗨️ GLOBAL CHAT | ✕ CLOSE + RAINBOW OUTLINE
-- ==============================================
local OWNER_USERNAME = "dwaynekean015"

local function ToggleGlobalChat()
    if ChatUI_Open then
        if CurrentChatUI then CurrentChatUI:Destroy() end
        ChatUI_Open = false
        CurrentChatUI = nil
        GuiFocused = false
        return
    end
    GuiFocused = true
    local ChatUI = Instance.new("ScreenGui")
    ChatUI.Name = "BLUE_GLOBAL_CHAT"
    ChatUI.ResetOnSpawn = false
    ChatUI.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ChatUI.Parent = PlayerGui
    CurrentChatUI = ChatUI
    ChatUI_Open = true

    -- MAIN FRAME WITH RAINBOW OUTLINE
    local ChatFrame = Instance.new("Frame")
    ChatFrame.Size = UDim2.new(0,500,0,400)
    ChatFrame.Position = UDim2.new(0.5,-250,0.5,-200)
    ChatFrame.BackgroundColor3 = Color3.fromRGB(22,22,22)
    ChatFrame.Active = true
    ChatFrame.Parent = ChatUI
    Instance.new("UICorner", ChatFrame).CornerRadius = UDim.new(0,12)
    -- ✅ RAINBOW GLOW/OUTLINE
    AddRainbowGlow(ChatFrame, 5)

    -- ✅ ✕ CLOSE BUTTON
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Size = UDim2.new(0,34,0,34)
    CloseBtn.Position = UDim2.new(1,-38,0,6)
    CloseBtn.BackgroundColor3 = Color3.fromRGB(180,40,40)
    CloseBtn.Text = "✕"
    CloseBtn.TextColor3 = Color3.new(1,1,1)
    CloseBtn.Font = Enum.Font.GothamBold
    CloseBtn.TextSize = 28
    CloseBtn.AutoLocalize = false
    CloseBtn.Parent = ChatFrame
    Instance.new("UICorner", CloseBtn).CornerRadius = UDim.new(0,8)
    CloseBtn.MouseButton1Click:Connect(function() ToggleGlobalChat() end)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1,-50,0,35)
    Title.Position = UDim2.new(0,15,0,6)
    Title.BackgroundTransparency = 1
    Title.Text = "🗨️ GLOBAL CHAT | BLUE MODE"
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.GothamBold
    Title.TextScaled = true
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = ChatFrame

    local ChatContainer = Instance.new("ScrollingFrame")
    ChatContainer.Size = UDim2.new(1,-30,0,270)
    ChatContainer.Position = UDim2.new(0,15,0,45)
    ChatContainer.BackgroundColor3 = Color3.fromRGB(35,35,35)
    ChatContainer.ScrollBarThickness = 6
    ChatContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
    ChatContainer.CanvasSize = UDim2.new(0,0,0,0)
    ChatContainer.Parent = ChatFrame
    Instance.new("UICorner", ChatContainer).CornerRadius = UDim.new(0,8)

    local MessageList = Instance.new("UIListLayout")
    MessageList.Padding = UDim.new(0,10)
    MessageList.HorizontalAlignment = Enum.HorizontalAlignment.Left
    MessageList.VerticalAlignment = Enum.VerticalAlignment.Top
    MessageList.Parent = ChatContainer

    local InputBox = Instance.new("TextBox")
    InputBox.Size = UDim2.new(1,-30,0,40)
    InputBox.Position = UDim2.new(0,15,0,325)
    InputBox.BackgroundColor3 = Color3.fromRGB(45,45,45)
    InputBox.PlaceholderText = "Type message & press Enter or SEND..."
    InputBox.TextColor3 = Color3.new(1,1,1)
    InputBox.Font = Enum.Font.Gotham
    InputBox.TextScaled = true
    InputBox.ClearTextOnFocus = false
    InputBox.Parent = ChatFrame
    Instance.new("UICorner", InputBox).CornerRadius = UDim.new(0,8)
    AddRainbowGlow(InputBox, 2)

    local SendBtn = Instance.new("TextButton")
    SendBtn.Size = UDim2.new(0,120,0,35)
    SendBtn.Position = UDim2.new(0.5,-60,0,370)
    SendBtn.BackgroundColor3 = Color3.fromRGB(30,150,90)
    SendBtn.Text = "📤 SEND MESSAGE"
    SendBtn.TextColor3 = Color3.new(1,1,1)
    SendBtn.Font = Enum.Font.GothamBold
    SendBtn.TextScaled = true
    SendBtn.Parent = ChatFrame
    Instance.new("UICorner", SendBtn).CornerRadius = UDim.new(0,8)
    AddRainbowGlow(SendBtn, 2)

    -- ✅ ADD MESSAGE WITH AVATAR + OWNER BADGE
    local function AddChatMessage(Player, Text)
        local MsgRow = Instance.new("Frame")
        MsgRow.Size = UDim2.new(1,-12,0,50)
        MsgRow.BackgroundTransparency = 1
        MsgRow.Parent = ChatContainer

        -- PLAYER AVATAR HEADSHOT
        local Avatar = Instance.new("ImageLabel")
        Avatar.Size = UDim2.new(0,42,0,42)
        Avatar.Position = UDim2.new(0,4,0,4)
        Avatar.BackgroundColor3 = Color3.fromRGB(60,60,60)
        Avatar.CornerRadius = UDim.new(1,0)
        Avatar.Image = "rbxthumb://type=AvatarHeadShot&id="..Player.UserId.."&w=100&h=100"
        Avatar.Parent = MsgRow

        -- USERNAME + OWNER TAG
        local NameTag = Instance.new("TextLabel")
        NameTag.Size = UDim2.new(1,55,0,22)
        NameTag.Position = UDim2.new(0,52,0,6)
        NameTag.BackgroundTransparency = 1
        NameTag.Font = Enum.Font.GothamBold
        NameTag.TextScaled = true
        NameTag.TextXAlignment = Enum.TextXAlignment.Left

        if string.lower(Player.Name) == string.lower(OWNER_USERNAME) then
            NameTag.Text = "👑 "..Player.Name.." • [OWNER]"
            NameTag.TextColor3 = Color3.fromRGB(255,215,0) -- GOLD YELLOW
        else
            NameTag.Text = Player.Name
            NameTag.TextColor3 = Color3.new(1,1,1)
        end
        NameTag.Parent = MsgRow

        -- MESSAGE TEXT
        local MsgText = Instance.new("TextLabel")
        MsgText.Size = UDim2.new(1,55,0,20)
        MsgText.Position = UDim2.new(0,52,0,28)
        MsgText.BackgroundTransparency = 1
        MsgText.Text = Text
        MsgText.TextColor3 = Color3.fromRGB(220,220,220)
        MsgText.Font = Enum.Font.Gotham
        MsgText.TextScaled = true
        MsgText.TextXAlignment = Enum.TextXAlignment.Left
        MsgText.TextWrapped = true
        MsgText.Parent = MsgRow

        -- AUTO SCROLL TO LATEST
        task.wait()
        ChatContainer.CanvasPosition = Vector2.new(0, ChatContainer.AbsoluteCanvasSize.Y)
    end

    -- SYSTEM MESSAGES
    local function AddSystemMsg(Text)
        local Sys = Instance.new("TextLabel")
        Sys.Size = UDim2.new(1,-12,0,30)
        Sys.BackgroundTransparency = 1
        Sys.Text = "ℹ️ "..Text
        Sys.TextColor3 = Color3.fromRGB(0,255,120)
        Sys.Font = Enum.Font.GothamSemibold
        Sys.TextScaled = true
        Sys.TextXAlignment = Enum.TextXAlignment.Left
        Sys.Parent = ChatContainer
        task.wait()
        ChatContainer.CanvasPosition = Vector2.new(0, ChatContainer.AbsoluteCanvasSize.Y)
    end

    -- WELCOME
    AddSystemMsg("Connected to Blue Mode Global Chat")
    AddSystemMsg("Owner: "..OWNER_USERNAME.." | Yellow Name + Crown Tag")

    -- SEND LOGIC
    local function SendMyMessage()
        local Msg = InputBox.Text
        if Msg == "" then return end
        if #Msg > 200 then AddSystemMsg("❌ Max 200 characters only") return end
        AddChatMessage(LocalPlayer, Msg)
        InputBox.Text = ""
    end

    SendBtn.MouseButton1Click:Connect(SendMyMessage)
    InputBox.FocusLost:Connect(function(EnterPressed)
        if EnterPressed then SendMyMessage() end
    end)
end
