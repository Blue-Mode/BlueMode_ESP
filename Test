    -- ✅ ADD MESSAGE WITH AVATAR + USERNAME + OWNER TAG
    local function AddChatMessage(Player, Message)
        local MsgContainer = Instance.new("Frame")
        MsgContainer.Size = UDim2.new(1,-12,0,44)
        MsgContainer.BackgroundTransparency = 1
        MsgContainer.Parent = ChatContainer

        -- PLAYER AVATAR
        local Avatar = Instance.new("ImageLabel")
        Avatar.Size = UDim2.new(0,38,0,38)
        Avatar.Position = UDim2.new(0,2,0,3)
        Avatar.BackgroundColor3 = Color3.fromRGB(50,50,50)
        Avatar.CornerRadius = UDim.new(1,0)
        Avatar.Image = "rbxthumb://type=AvatarHeadShot&id="..Player.UserId.."&w=150&h=150"
        Avatar.Parent = MsgContainer

        -- USERNAME + OWNER TAG
        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size = UDim2.new(1,50,0,20)
        NameLabel.Position = UDim2.new(0,48,0,5)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Font = Enum.Font.GothamBold
        NameLabel.TextScaled = true
        NameLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        if Player.Name == OWNER_USERNAME then
            NameLabel.Text = "👑 "..Player.Name.." [OWNER]"
            NameLabel.TextColor3 = Color3.fromRGB(255,215,0) -- GOLD/YELLOW FOR OWNER
        else
            NameLabel.Text = Player.Name
            NameLabel.TextColor3 = Color3.new(1,1,1)
        end
        NameLabel.Parent = MsgContainer

        -- MESSAGE TEXT
        local MsgText = Instance.new("TextLabel")
        MsgText.Size = UDim2.new(1,50,0,18)
        MsgText.Position = UDim2.new(0,48,0,25)
        MsgText.BackgroundTransparency = 1
        MsgText.Text = Message
        MsgText.TextColor3 = Color3.new(0.9,0.9,0.9)
        MsgText.Font = Enum.Font.Gotham
        MsgText.TextScaled = true
        MsgText.TextXAlignment = Enum.TextXAlignment.Left
        MsgText.TextWrapped = true
        MsgText.Parent = MsgContainer

        -- AUTO SCROLL TO BOTTOM
        task.wait()
        ChatContainer.CanvasPosition = Vector2.new(0, ChatContainer.AbsoluteCanvasSize.Y)
    end

    -- SYSTEM MESSAGE
    local function AddSystemMessage(Text)
        local SysMsg = Instance.new("TextLabel")
        SysMsg.Size = UDim2.new(1,-12,0,28)
        SysMsg.BackgroundTransparency = 1
        SysMsg.Text = "ℹ️ "..Text
        SysMsg.TextColor3 = Color3.fromRGB(0,255,120)
        SysMsg.Font = Enum.Font.Gotham
        SysMsg.TextScaled = true
        SysMsg.TextXAlignment = Enum.TextXAlignment.Left
        SysMsg.Parent = ChatContainer
        task.wait()
        ChatContainer.CanvasPosition = Vector2.new(0, ChatContainer.AbsoluteCanvasSize.Y)
    end

    -- WELCOME MESSAGES
    AddSystemMessage("Welcome to Blue Mode Global Chat!")
    AddSystemMessage("Owner: "..OWNER_USERNAME)

    -- SEND MESSAGE FUNCTION
    local function SendMessage()
        local Msg = InputBox.Text
        if Msg == "" then return end
        if #Msg > 200 then AddSystemMessage("Message too long! Max 200 characters") return end
        
        AddChatMessage(LocalPlayer, Msg)
        InputBox.Text = ""
    end

    SendBtn.MouseButton1Click:Connect(SendMessage)
    InputBox.FocusLost:Connect(function(enterPressed) if enterPressed then SendMessage() end end)
end

